# LLM: any litellm-compatible provider. Gemini free tier works great:
#   get a key in 60s at https://aistudio.google.com/apikey
LLM_PROVIDER="gemini"
LLM_MODEL="gemini/gemini-2.5-flash"
LLM_API_KEY="<your-key>"

# Embeddings run 100% LOCALLY via fastembed (ONNX) — no API, no data leaves your machine.
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
EMBEDDING_DIMENSIONS=384

# ALTERNATIVE: got only a Vertex express-mode key (starts with "AQ.")? Set this and
# gitmem bridges litellm to aiplatform.googleapis.com automatically (see vertex_express.py):
#VERTEX_EXPRESS_KEY="AQ.your-express-key"
#COGNEE_SKIP_CONNECTION_TEST=true
